---
import { worldCountriesEn, worldCountriesRu, worldCountriesTt } from "@/data/worldCountries";
import { Icon } from "astro-icon/components";

interface CardLink {
	type: string;
	url: string;
	label?: string;
}

interface Location {
	flag?: string;
	city?: string;
	country?: string;
	address?: string;
}

interface Props {
	id: string;
	title?: string;
	summary?: string;
	type?: string;
	category?: string;
	location?: Location;
	links?: CardLink[];
	pubDate?: string | Date;
	region?: string;
}

const { id, title, summary, type, category, location, links = [], pubDate, region } =
	Astro.props as Props;
const NINETY_DAYS = 90 * 24 * 60 * 60 * 1000;
const isNew = pubDate ? Date.now() - new Date(pubDate).getTime() < NINETY_DAYS : false;

const NO_DATA = "Нет данных.";
const cleanFlag = location?.flag && location.flag !== NO_DATA ? location.flag : undefined;
const cleanCity = location?.city && location.city !== NO_DATA ? location.city : undefined;
const cleanCountry =
	location?.country && location.country !== NO_DATA ? location.country : undefined;
const countryLabelsByLanguage = Object.fromEntries(
	worldCountriesRu.map((country, index) => [
		country,
		{
			en: worldCountriesEn[index] ?? country,
			ru: country,
			tt: worldCountriesTt[index] ?? country,
		},
	]),
) as Record<string, { en: string; ru: string; tt: string }>;
const displayCountry = cleanCountry
	? (countryLabelsByLanguage[cleanCountry]?.en ?? cleanCountry)
	: undefined;
const countryKey = cleanCountry ?? "Прочее";
const countryLabels = cleanCountry
	? (countryLabelsByLanguage[cleanCountry] ?? {
			en: cleanCountry,
			ru: cleanCountry,
			tt: cleanCountry,
		})
	: undefined;

const isDump =
	summary &&
	(summary.startsWith("Полное название:") ||
		summary.startsWith("Тел.:") ||
		summary.startsWith("Адрес:") ||
		summary.length > 400);
const displaySummary = isDump ? undefined : summary;

const socialLinks = links.filter((l) => !["email", "phone"].includes(l.type.toLowerCase()));

const iconMap: Record<string, string> = {
	instagram: "mdi:instagram",
	telegram: "mdi:telegram",
	vk: "mdi:vk",
	facebook: "mdi:facebook",
	youtube: "mdi:youtube",
	tiktok: "mdi:tiktok",
	twitter: "mdi:twitter",
	site: "mdi:web",
	web: "mdi:web",
	website: "mdi:web",
};

function getIcon(type: string): string {
	return iconMap[type.toLowerCase()] ?? "mdi:web";
}

function getLinkLabel(link: CardLink) {
	const kind = link.label?.trim() || link.type.trim();
	return `Open ${kind}`;
}
---

<a
	href={`/list/centers/${id}`}
	// These attributes are the filtering contract used by the list toolbar on the client.
	data-type={type ?? ""}
	data-category={category ?? ""}
	data-country={countryKey}
	data-region={region ?? ""}
	data-title={title ?? ""}
	data-summary={summary ?? ""}
	data-city={cleanCity ?? ""}
	data-date={pubDate ? new Date(pubDate).toISOString() : ""}
	class="block h-full"
>
	<article
		class="group h-full relative flex flex-col gap-3 rounded-2xl corner-squircle bg-surface p-5 ring-1 ring-border-muted transition-all hover:shadow-sm hover:ring-ring"
	>
		<div class="flex items-start justify-between gap-2">
			{
				(cleanFlag || cleanCity || displayCountry) && (
					<div class="flex items-center gap-1.5 text-xs text-subtle-foreground">
						{cleanFlag && <span class="text-base leading-none">{cleanFlag}</span>}
						{cleanCity && <span>{cleanCity}</span>}
						{cleanCity && countryLabels && <span aria-hidden="true">&#10625;</span>}
						{countryLabels && (
							<span
								data-country-label={cleanCountry}
								data-country-labels={JSON.stringify(countryLabels)}
							>
								{countryLabels.en}
							</span>
						)}
					</div>
				)
			}
		</div>

		<h2 class="line-clamp-2 font-semibold leading-snug text-surface-foreground">
			{title ?? "—"}
		</h2>

		{
			displaySummary && (
				<p class="line-clamp-3 grow text-xs leading-relaxed text-muted-foreground">
					{displaySummary}
				</p>
			)
		}

		<div class="mt-auto flex items-center justify-between gap-2 pt-1">
			{
				socialLinks.length > 0 && (
					<div class="flex flex-wrap gap-1.5">
						{socialLinks.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								title={link.label ?? link.type}
								aria-label={getLinkLabel(link)}
								class="flex h-7 w-7 items-center justify-center rounded-lg corner-squircle bg-muted text-muted-foreground transition hover:bg-subtle hover:text-foreground"
							>
								<Icon name={getIcon(link.type)} class="h-4 w-4" aria-hidden="true" />
							</a>
						))}
					</div>
				)
			}
		</div>
	</article>
</a>
