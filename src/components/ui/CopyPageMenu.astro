---
import { cn } from "@/utils/libs/cn";

interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;
---

<div class={cn("relative inline-flex", className)} data-copy-page-menu>
	<div class="group relative flex rounded-lg bg-muted">
		<!-- Copy Page button -->
		<button
			type="button"
			class="inline-flex text-sm h-9 items-center gap-1.5 rounded-l-lg pl-2.5 pr-2.5 text-[0.8rem] font-medium text-foreground transition-colors hover:bg-border/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
			data-copy-btn
			aria-label="Copy page URL"
		>
			<!-- default: copy icon -->
			<svg
				data-icon-copy
				viewBox="0 0 24 24"
				class="size-3.5 shrink-0"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
			>
				<rect x="8" y="7" width="12" height="12" rx="3"></rect>
				<path d="M16 7V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h1"></path>
			</svg>
			<!-- copied: check icon (hidden by default) -->
			<svg
				data-icon-check
				viewBox="0 0 24 24"
				class="hidden size-3.5 shrink-0 text-muted-foreground"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
			>
				<path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
			<span data-copy-label class="sm:inline hidden">Copy url</span>
		</button>

		<!-- Separator -->
		<span
			class="pointer-events-none absolute top-1 right-9 z-0 h-7 w-px bg-foreground/10"
			aria-hidden="true"></span>

		<!-- Chevron / dropdown trigger -->
		<button
			type="button"
			class="inline-flex size-9 shrink-0 items-center justify-center rounded-r-lg text-foreground transition-colors hover:bg-border/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
			aria-haspopup="menu"
			aria-expanded="false"
			aria-controls="copy-page-dropdown"
			aria-label="More options"
			data-chevron-btn
		>
			<svg
				viewBox="0 0 20 20"
				class="size-3.5 transition-transform duration-150"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				data-chevron-icon
			>
				<path d="m5 7 5 5 5-5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>

		<!-- Dropdown panel -->
		<div
			id="copy-page-dropdown"
			role="menu"
			aria-label="Open page in"
			class="absolute right-0 top-[calc(100%+0.375rem)] z-50 hidden min-w-[200px] rounded-lg border border-border bg-surface p-1 shadow-md"
			data-dropdown
		>
