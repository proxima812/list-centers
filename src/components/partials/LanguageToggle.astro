---
const items = [
	{ value: "en", label: "English", text: "EN" },
	{ value: "ru", label: "Русский", text: "RU" },
	{ value: "tt", label: "Татарча", text: "TT" },
];

const buttonClass =
	"inline-flex h-8 min-w-8 items-center justify-center rounded-full px-2 tracking-tight text-xs font-medium text-subtle-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40 aria-checked:bg-muted aria-checked:text-foreground";
---

<div
	class="inline-flex items-center gap-0.5 rounded-full border border-border-muted p-0.5"
	role="radiogroup"
	aria-label="Language switcher"
	data-i18n-aria-label="language.switcher"
	data-language-switcher
>
	{
		items.map((item, index) => (
			<button
				type="button"
				class={buttonClass}
				data-language-option={item.value}
				role="radio"
				aria-label={item.label}
				aria-checked={index === 0 ? "true" : "false"}
				tabindex={index === 0 ? "0" : "-1"}
			>
				{item.text}
			</button>
		))
	}
</div>
